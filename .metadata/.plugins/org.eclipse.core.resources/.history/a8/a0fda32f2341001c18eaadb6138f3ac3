package com.gaurav;

public class Gaurav {

	private int id;
	private String name;
	private String color;
	private Mother mother;

	public Gaurav() {
		super();
	}

	public Gaurav(int id, String name, String color, Mother mother) {
		super();
		this.id = id;
		this.name = name;
		this.color = color;
		this.mother = mother;
	}

	public int getId() {
		return id;
	}

	public void setId(int id) {
		this.id = id;
	}

	public String getName() {
		return name;
	}

	public void setName(String name) {
		this.name = name;
	}

	public String getColor() {
		return color;
	}

	public void setColor(String color) {
		this.color = color;
	}

	public Mother getMother() {
		return mother;
	}

	public void setMother(Mother mother) {
		this.mother = mother;
	}

	@Override
	public String toString() {
		return "Gaurav [id=" + id + ", name=" + name + ", color=" + color + ", mother=" + mother + "]";
	}

}
